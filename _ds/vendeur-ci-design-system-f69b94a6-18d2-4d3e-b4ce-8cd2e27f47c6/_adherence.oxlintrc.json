{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/commerce/**",
              "components/core/**",
              "components/navigation/**",
              "ui_kits/mobile-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Sora|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Sora, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|shape|verified|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, shape, verified, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|rounded)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'rounded'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|size|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, icon, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|primary|active|paused|expired|vedette|negociable|whatsapp|solidBlue|solidAmber|free|essentiel|pro)$/]",
        "message": "<Badge> variant must be one of 'neutral' | 'primary' | 'active' | 'paused' | 'expired' | 'vedette' | 'negociable' | 'whatsapp' | 'solidBlue' | 'solidAmber' | 'free' | 'essentiel' | 'pro'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: icon, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|icon|iconRight|disabled|loading|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, fullWidth, icon, iconRight, disabled, loading, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|whatsapp|call|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'whatsapp' | 'call' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|icon|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, selected, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|tone|size|badge|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, tone, size, badge, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|primary|onPhoto|onBlue)$/]",
        "message": "<IconButton> tone must be one of 'neutral' | 'primary' | 'onPhoto' | 'onBlue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|icon|prefix|suffix|error|hint|containerStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, icon, prefix, suffix, error, hint, containerStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProductCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|price|currency|photo|ghostIcon|accent|seller|vedette|negociable|favorite|unavailable|onToggleFavorite|key|ref|className|style|children)$/]",
        "message": "<ProductCard> doesn't accept that prop. Declared props: title, price, currency, photo, ghostIcon, accent, seller, vedette, negociable, favorite, unavailable, onToggleFavorite."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|placeholder|asButton|onChange|onFilter|filterActive|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: value, placeholder, asButton, onChange, onFilter, filterActive."
      },
      {
        "selector": "JSXOpeningElement[name.name='SellerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|photo|rating|vedette|key|ref|className|style|children)$/]",
        "message": "<SellerCard> doesn't accept that prop. Declared props: name, photo, rating, vedette."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|count|size|interactive|onChange|showValue|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, count, size, interactive, onChange, showValue."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<StarRating> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|label|tone|trend|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: icon, value, label, tone, trend."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|gray|amber)$/]",
        "message": "<StatCard> tone must be one of 'blue' | 'green' | 'gray' | 'amber'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
